# Site URL (optional — defaults to https://cimattiandroberts.co.uk)
# NEXT_PUBLIC_SITE_URL=https://cimattiandroberts.co.uk

# Web3Forms access key — get yours free at https://web3forms.com
# Replace YOUR_ACCESS_KEY_HERE with your key, or set in Vercel/hosting env vars
NEXT_PUBLIC_WEB3FORMS_KEY=YOUR_ACCESS_KEY_HERE

# Search engine verification (optional — add when registering with Search Console)
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
# NEXT_PUBLIC_BING_SITE_VERIFICATION=your-bing-verification-code
# NEXT_PUBLIC_YANDEX_SITE_VERIFICATION=your-yandex-verification-code
